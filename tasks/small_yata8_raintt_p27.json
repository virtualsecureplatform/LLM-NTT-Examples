{
  "id": "small_yata8_raintt_p27",
  "name": "Small YATA RAINTT 8-point RTL",
  "status": "correctness_scored",
  "description": "Single radix-8 YATA compressed RAINTT RTL reference top.",
  "implementation_notes": [
    "RTL uses the RAINTT SREDC-style modular reduction path.",
    "Generated YATA datapath intentionally avoids Verilog modulo operators."
  ],
  "variant": "small-ntt",
  "top_module": "SmallYata8RainttP27Rtl",
  "verilog": {
    "candidate_file": "SmallYata8RainttP27Rtl.sv",
    "default_path": "variants/small-ntt/rtl/SmallYata8RainttP27Rtl.sv"
  },
  "evaluation": {
    "mode": "verilator_test",
    "cmake_cache_var": "SMALL_YATA8_VERILOG",
    "test_target": "small_yata8_reference_test",
    "watchdog_cycles": 500
  },
  "parameters": {
    "N": 8,
    "Nbit": 3,
    "modulus": 40960001,
    "modulus_hex": "0x02710001",
    "word_bits": 27,
    "torus_bits": 32,
    "lanes": 8,
    "stream_cycles": 1,
    "radix": 8,
    "prime_form": "5^4 * 2^16 + 1"
  },
  "ports": {
    "clock": "clock",
    "reset": "reset",
    "intt_valid_in": "io_intt_validin",
    "intt_valid_out": "io_intt_validout",
