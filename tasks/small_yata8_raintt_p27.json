    "intt_output_lanes": "io_intt_out_0..io_intt_out_7",
    "ntt_valid_in": "io_ntt_validin",
    "ntt_valid_out": "io_ntt_validout",
    "ntt_input_lanes": "io_ntt_in_0..io_ntt_in_7",
    "ntt_output_lanes": "io_ntt_out_0..io_ntt_out_7"
  },
  "reference": {
    "library": "TFHEpp",
    "include": "raintt.hpp",
    "table": "raintt::TableGen<3>()",
    "twist": "raintt::TwistGen<3, 3>()",
    "intt": "raintt::TwistINTT<uint32_t, 3, false>",
    "ntt": "raintt::NTTradixButterfly<3> plus raintt::TwistMulDirect<uint32_t, 3, true>"
  },
  "observable_contract": {
    "intt_input_order": "input_index = lane",
    "intt_output_order": "expected_index = lane",
    "ntt_input_order": "input_index = lane",
    "ntt_output_order": "expected_index = lane"
  },
  "score": {
    "correctness": "required",
